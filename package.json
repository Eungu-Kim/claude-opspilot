{
  "name": "opspilot",
  "version": "0.0.1",
  "description": "AI Workspace for Operations Engineers — Working Context MCP server",
  "type": "module",
  "private": true,
  "bin": {
    "opspilot": "dist/index.js",
    "opspilot-cli": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc && npm run copy:assets",
    "copy:assets": "cp src/db/schema.sql dist/db/schema.sql",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "cli": "node dist/cli.js",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "better-sqlite3": "^11.8.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
